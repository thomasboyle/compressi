<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Styles/Typography.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- 8-bit cottagecore / matcha theme (legacy Glass* keys retained) -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="GlassPanelFillBrush" Color="#FFF7F0E2" />
            <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#FFA7A28B" />
            <SolidColorBrush x:Key="GlassPanelSpecularBrush" Color="#00FFFFFF" />
            <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#FFE8DFD0" />
            <SolidColorBrush x:Key="AppInkBrush" Color="#FF2A3220" />
            <SolidColorBrush x:Key="NavSelectionBrush" Color="#FFC2C3A2" />
            <SolidColorBrush x:Key="StippleFillBrush" Color="#FFC2C3A2" />
            <SolidColorBrush x:Key="StippleButtonBrush" Color="#FFA8AA8C" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="GlassPanelFillBrush" Color="#FFF7F0E2" />
            <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#FFA7A28B" />
            <SolidColorBrush x:Key="GlassPanelSpecularBrush" Color="#00FFFFFF" />
            <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#FFE8DFD0" />
            <SolidColorBrush x:Key="AppInkBrush" Color="#FF2A3220" />
            <SolidColorBrush x:Key="NavSelectionBrush" Color="#FFC2C3A2" />
            <SolidColorBrush x:Key="StippleFillBrush" Color="#FFC2C3A2" />
            <SolidColorBrush x:Key="StippleButtonBrush" Color="#FFA8AA8C" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="GlassPanelFillBrush" Color="#FF2A2924" />
            <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#FF8F9A6E" />
            <SolidColorBrush x:Key="GlassPanelSpecularBrush" Color="#00FFFFFF" />
            <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#FF1E1D1A" />
            <SolidColorBrush x:Key="AppInkBrush" Color="#FFE8E0D0" />
            <SolidColorBrush x:Key="NavSelectionBrush" Color="#FF6F7358" />
            <SolidColorBrush x:Key="StippleFillBrush" Color="#FF6F7358" />
            <SolidColorBrush x:Key="StippleButtonBrush" Color="#FF5A5E48" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <CornerRadius x:Key="GlassPanelCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="GlassButtonCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="GlassPillCornerRadius">4</CornerRadius>

    <Color x:Key="GlassPanelFillLightColor">#FFF7F0E2</Color>
    <Color x:Key="GlassPanelFillDarkColor">#FF2A2924</Color>
    <Color x:Key="GlassBorderHighlightColor">#FF5A6540</Color>
    <Color x:Key="GlassBorderHighlightDarkColor">#FF8F9A6E</Color>

    <SolidColorBrush x:Key="GlassPanelFillLightBrush" Color="{StaticResource GlassPanelFillLightColor}" />
    <SolidColorBrush x:Key="GlassPanelFillDarkBrush" Color="{StaticResource GlassPanelFillDarkColor}" />
    <SolidColorBrush x:Key="GlassBorderHighlightBrush" Color="{StaticResource GlassBorderHighlightColor}" />
    <SolidColorBrush x:Key="GlassBorderHighlightDarkBrush" Color="{StaticResource GlassBorderHighlightDarkColor}" />

    <Color x:Key="PrimaryBlueColor">#FF8F9A6E</Color>
    <Color x:Key="PrimaryBlueLightColor">#FFA7B18F</Color>
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlueColor}" />

    <Color x:Key="SuccessGreenColor">#FF5F6B45</Color>
    <Color x:Key="ResultSurfaceColor">#FFFFFBF3</Color>
    <Color x:Key="ResultCardBorderColor">#FF6B744F</Color>
    <Color x:Key="ResultLabelColor">#FF5A564C</Color>
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreenColor}" />
    <SolidColorBrush x:Key="ResultSurfaceBrush" Color="{StaticResource ResultSurfaceColor}" />
    <SolidColorBrush x:Key="ResultCardBorderBrush" Color="{StaticResource ResultCardBorderColor}" />
    <SolidColorBrush x:Key="ResultLabelBrush" Color="{StaticResource ResultLabelColor}" />

    <Color x:Key="PrimaryBlueHoverColor">#FF7E895F</Color>
    <Color x:Key="PrimaryBlueHoverLightColor">#FF98A37F</Color>
    <Color x:Key="PrimaryBluePressedColor">#FF6A744C</Color>
    <Color x:Key="PrimaryBluePressedLightColor">#FF8F9A6E</Color>

    <SolidColorBrush x:Key="PrimaryBlueGradientBrush" Color="{StaticResource PrimaryBlueLightColor}" />
    <SolidColorBrush x:Key="PrimaryBlueHoverGradientBrush" Color="{StaticResource PrimaryBlueHoverLightColor}" />
    <SolidColorBrush x:Key="PrimaryBluePressedGradientBrush" Color="{StaticResource PrimaryBluePressedColor}" />

    <SolidColorBrush x:Key="GlassSpecularHighlightBrush" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="GlassSpecularHighlightDarkBrush" Color="#00FFFFFF" />

    <SolidColorBrush x:Key="GlassTrackBrush" Color="#33000000" />
    <SolidColorBrush x:Key="GlassTrackDarkBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="InputSurfaceBrush" Color="{StaticResource ResultSurfaceColor}" />

    <Color x:Key="DropZoneFillColor">#14A7B18F</Color>
    <Color x:Key="DropZoneFillHoverColor">#28A7B18F</Color>
    <Color x:Key="DropZoneStrokeColor">#FF4F5838</Color>
    <Color x:Key="DropZoneStrokeHoverColor">#FF2A3220</Color>
    <SolidColorBrush x:Key="DropZoneFillBrush" Color="{StaticResource DropZoneFillColor}" />
    <SolidColorBrush x:Key="DropZoneFillHoverBrush" Color="{StaticResource DropZoneFillHoverColor}" />
    <SolidColorBrush x:Key="DropZoneStrokeBrush" Color="{StaticResource DropZoneStrokeColor}" />
    <SolidColorBrush x:Key="DropZoneStrokeHoverBrush" Color="{StaticResource DropZoneStrokeHoverColor}" />
    <SolidColorBrush x:Key="DropZoneIconBackgroundBrush" Color="#33C2C3A2" />

    <Color x:Key="FeaturePurpleColor">#FF7A6B5D</Color>
    <Color x:Key="FeatureOrangeColor">#FFB07A45</Color>
    <Color x:Key="FeatureGreenBackgroundColor">#FFE8ECD9</Color>
    <Color x:Key="FeaturePurpleBackgroundColor">#FFF0E8DC</Color>
    <Color x:Key="FeatureBlueBackgroundColor">#FFE8ECD9</Color>
    <Color x:Key="FeatureOrangeBackgroundColor">#FFF5EADB</Color>
    <Color x:Key="SecurityBannerBorderColor">#FF8F9A6E</Color>
    <SolidColorBrush x:Key="FeaturePurpleBrush" Color="{StaticResource FeaturePurpleColor}" />
    <SolidColorBrush x:Key="FeatureOrangeBrush" Color="{StaticResource FeatureOrangeColor}" />
    <SolidColorBrush x:Key="FeatureGreenBackgroundBrush" Color="{StaticResource FeatureGreenBackgroundColor}" />
    <SolidColorBrush x:Key="FeaturePurpleBackgroundBrush" Color="{StaticResource FeaturePurpleBackgroundColor}" />
    <SolidColorBrush x:Key="FeatureBlueBackgroundBrush" Color="{StaticResource FeatureBlueBackgroundColor}" />
    <SolidColorBrush x:Key="FeatureOrangeBackgroundBrush" Color="{StaticResource FeatureOrangeBackgroundColor}" />
    <SolidColorBrush x:Key="SecurityBannerBorderBrush" Color="{StaticResource SecurityBannerBorderColor}" />
    <SolidColorBrush x:Key="SecurityBannerFillBrush" Color="#FFE4E8D4" />

    <Style x:Key="GlassInputComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="MinHeight" Value="31" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
    </Style>

    <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinHeight" Value="31" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="GlassToggleSwitchStyle" TargetType="ToggleSwitch">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="GlassSliderStyle" TargetType="Slider">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBlueBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="GlassDisclosureToggleStyle" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="MinHeight" Value="31" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{TemplateBinding Foreground}" />
                            <FontIcon
                                x:Name="Chevron"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{TemplateBinding Foreground}"
                                Glyph="&#xE70D;" />
                        </Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource DropZoneStrokeBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed" />
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.45"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Unchecked" />
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Chevron" Storyboard.TargetProperty="Glyph">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="&#xE70E;" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassInfoBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="GlassFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontBoldFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}" />
        <Setter Property="Foreground" Value="{StaticResource ResultLabelBrush}" />
    </Style>

    <Style x:Key="GlassFormatRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="Height" Value="31" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontBoldFamily}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}"
                            FontFamily="{TemplateBinding FontFamily}"
                            Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver" />
                                <VisualState x:Name="Pressed" />
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource StippleFillBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0">
                                                <DiscreteObjectKeyFrame.Value>
                                                    <SolidColorBrush Color="#FF2A3220" />
                                                </DiscreteObjectKeyFrame.Value>
                                            </DiscreteObjectKeyFrame>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unchecked" />
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource StippleButtonBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource GlassButtonCornerRadius}" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="16,5" />
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontBoldFamily}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}" />
        <Setter Property="BorderBrush" Value="#FF2A3220" />
        <Setter Property="BorderThickness" Value="1,1,1,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            FontFamily="{TemplateBinding FontFamily}"
                            Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.9"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderThickness">
                                            <DiscreteObjectKeyFrame KeyTime="0">
                                                <DiscreteObjectKeyFrame.Value>
                                                    <Thickness>2</Thickness>
                                                </DiscreteObjectKeyFrame.Value>
                                            </DiscreteObjectKeyFrame>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.45"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassSecondaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="Background" Value="{StaticResource ResultSurfaceBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource GlassButtonCornerRadius}" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1,1,1,2" />
    </Style>

    <Style x:Key="GlassDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
        <Setter Property="Foreground" Value="#FF9B3B3B" />
        <Setter Property="BorderBrush" Value="#669B3B3B" />
    </Style>

    <Style x:Key="GlassSecondaryToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource AppPixelFontFamily}" />
        <Setter Property="Background" Value="{StaticResource ResultSurfaceBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource GlassButtonCornerRadius}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="BorderBrush" Value="{StaticResource ResultCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="2,2,2,3" />
    </Style>

</ResourceDictionary>
