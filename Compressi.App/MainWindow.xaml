<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Compressi_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Compressi_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Compressi"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.RowSpan="2"
            IsHitTestVisible="False"
            Opacity="0.28">
            <Border.Background>
                <ImageBrush
                    ImageSource="ms-appx:///Assets/ui/texture-grain.png"
                    Stretch="UniformToFill" />
            </Border.Background>
        </Border>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Compressi"
            Foreground="{ThemeResource AppInkBrush}">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#F8F0E3" />
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#F8F0E3" />
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#C2C3A2" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#B5B895" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="#A8AB88" />
                <Thickness x:Key="NavigationViewContentMargin">0</Thickness>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <StackPanel
                    Margin="12,8,12,4"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Image
                        Width="36"
                        Height="36"
                        Source="Assets/AppLogo.png"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AppInkBrush}"
                        Text="Compressi" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Compress" Tag="Compress">
                    <NavigationViewItem.Icon>
                        <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/ui/nav-compress.png" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="History" Tag="History">
                    <NavigationViewItem.Icon>
                        <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/ui/nav-history.png" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/ui/nav-settings.png" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="About">
                    <NavigationViewItem.Icon>
                        <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/ui/nav-about.png" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel
                    Margin="12,8,12,20"
                    HorizontalAlignment="Center"
                    Spacing="8">
                    <Image
                        Width="140"
                        Height="170"
                        HorizontalAlignment="Center"
                        Source="ms-appx:///Assets/ui/smoothie.png"
                        Stretch="Uniform" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        FontStyle="Italic"
                        Foreground="{StaticResource ResultLabelBrush}"
                        Text="Smooth results, every time."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <ContentPresenter x:Name="ContentHost" />
        </NavigationView>
    </Grid>
</Window>
