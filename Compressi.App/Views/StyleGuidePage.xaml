<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Compressi_App.Views.StyleGuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Compressi_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="32" MaxWidth="900">
            <TextBlock Style="{StaticResource DisplayTextStyle}" Text="Compressi Style Guide" />

            <TextBlock Style="{StaticResource TitleTextStyle}" Text="Typography" />
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource DisplayTextStyle}" Text="Display — 28px SemiBold" />
                <TextBlock Style="{StaticResource TitleTextStyle}" Text="Title — 20px SemiBold" />
                <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="Subtitle — 16px Medium" />
                <TextBlock Style="{StaticResource BodyTextStyle}" Text="Body — 14px Regular" />
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Caption — 12px Regular, 70% opacity" />
            </StackPanel>

            <TextBlock Style="{StaticResource TitleTextStyle}" Text="Glass Panel" />
            <controls:GlassPanel MinHeight="160">
                <controls:GlassPanel.PanelContent>
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="GlassPanel surface" />
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="Rounded corners, semi-transparent fill, inner highlight border, specular top sheen, and ThemeShadow." />
                    </StackPanel>
                </controls:GlassPanel.PanelContent>
            </controls:GlassPanel>

            <TextBlock Style="{StaticResource TitleTextStyle}" Text="Buttons" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Content="Start Compression" Style="{StaticResource GlassPrimaryButtonStyle}" />
                <Button Content="Open Output Folder" Style="{StaticResource GlassSecondaryButtonStyle}" />
            </StackPanel>

            <TextBlock Style="{StaticResource TitleTextStyle}" Text="Accent &amp; Progress" />
            <StackPanel Spacing="12" MaxWidth="400">
                <Border
                    Height="40"
                    Background="{StaticResource PrimaryBlueGradientBrush}"
                    CornerRadius="{StaticResource GlassButtonCornerRadius}" />
                <ProgressBar
                    Maximum="100"
                    Value="65"
                    Foreground="{StaticResource PrimaryBlueBrush}" />
                <Slider Maximum="100" Value="50" Width="300" />
            </StackPanel>

            <TextBlock Style="{StaticResource TitleTextStyle}" Text="Color Tokens" />
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Height="64"
                    Background="{StaticResource PrimaryBlueBrush}"
                    CornerRadius="8" />
                <Border
                    Grid.Column="1"
                    Height="64"
                    Background="{StaticResource GlassPanelFillLightBrush}"
                    BorderBrush="{StaticResource GlassBorderHighlightBrush}"
                    BorderThickness="1"
                    CornerRadius="8" />
                <Border
                    Grid.Column="2"
                    Height="64"
                    Background="{StaticResource PrimaryBlueGradientBrush}"
                    CornerRadius="8" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
