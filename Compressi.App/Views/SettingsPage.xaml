<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Compressi_App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Compressi_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <controls:GlassPanel>
            <controls:GlassPanel.PanelContent>
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Spacing="20"
                        MaxWidth="640">
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="Settings" />

                        <Border
                            x:Name="SettingsBanner"
                            Style="{StaticResource GlassInfoBannerStyle}"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="SettingsBannerTitle"
                                        Style="{StaticResource BodyTextStyle}"
                                        FontFamily="{StaticResource AppPixelFontBoldFamily}"
                                        Visibility="Collapsed" />
                                    <TextBlock
                                        x:Name="SettingsBannerMessage"
                                        Style="{StaticResource BodyTextStyle}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Dismiss status"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="SettingsBannerCloseButton_Click"
                                    Content="&#xE711;"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Foreground="{StaticResource ResultLabelBrush}" />
                            </Grid>
                        </Border>

                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Default output folder" />
                            <TextBox
                                x:Name="OutputFolderBox"
                                PlaceholderText="Leave empty to use source file folder"
                                Style="{StaticResource GlassTextBoxStyle}"
                                TextChanged="OutputFolderBox_TextChanged" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Default preset" />
                            <ComboBox
                                x:Name="DefaultPresetBox"
                                SelectionChanged="DefaultPresetBox_SelectionChanged"
                                Style="{StaticResource GlassInputComboBoxStyle}">
                                <ComboBoxItem
                                    Content="Ultra"
                                    Tag="Ultra"
                                    ToolTipService.ToolTip="Smallest file size with reduced video quality. Best for archiving or slow connections." />
                                <ComboBoxItem
                                    Content="8MB"
                                    Tag="EightMB"
                                    ToolTipService.ToolTip="Targets an 8MB file while keeping audio and frame rate as high as possible. Great for Discord and chat sharing." />
                                <ComboBoxItem
                                    Content="Balanced"
                                    Tag="Balanced"
                                    ToolTipService.ToolTip="Solid quality-to-size tradeoff for everyday sharing." />
                            </ComboBox>
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="HardwareToggle"
                            Style="{StaticResource GlassToggleSwitchStyle}"
                            Toggled="HardwareToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="Hardware acceleration (GPU AV1 when available)" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="CPU thread usage" />
                            <Slider
                                x:Name="ThreadSlider"
                                Maximum="64"
                                Minimum="0"
                                StepFrequency="1"
                                Style="{StaticResource GlassSliderStyle}"
                                ValueChanged="ThreadSlider_ValueChanged" />
                            <TextBlock x:Name="ThreadCountLabel" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Theme" />
                            <ComboBox
                                x:Name="ThemeBox"
                                SelectionChanged="ThemeBox_SelectionChanged"
                                Style="{StaticResource GlassInputComboBoxStyle}">
                                <ComboBoxItem Content="System" Tag="System" />
                                <ComboBoxItem Content="Light" Tag="Light" />
                                <ComboBoxItem Content="Dark" Tag="Dark" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <ToggleSwitch
                                x:Name="NotifyToggle"
                                Style="{StaticResource GlassToggleSwitchStyle}"
                                Toggled="NotifyToggle_Toggled">
                                <ToggleSwitch.Header>
                                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="Notification on completion" />
                                </ToggleSwitch.Header>
                            </ToggleSwitch>
                            <TextBlock
                                x:Name="NotifyUnavailableText"
                                Foreground="{StaticResource ResultLabelBrush}"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="Desktop notifications are unavailable in this install."
                                TextWrapping="WrapWholeWords"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="UiSoundsToggle"
                            Style="{StaticResource GlassToggleSwitchStyle}"
                            Toggled="UiSoundsToggle_Toggled">
                            <ToggleSwitch.Header>
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="UI interaction sounds" />
                            </ToggleSwitch.Header>
                        </ToggleSwitch>

                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="UI sound volume" />
                            <Slider
                                x:Name="UiSoundVolumeSlider"
                                Maximum="100"
                                Minimum="0"
                                StepFrequency="1"
                                Style="{StaticResource GlassSliderStyle}"
                                ValueChanged="UiSoundVolumeSlider_ValueChanged" />
                            <TextBlock x:Name="UiSoundVolumeLabel" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="Detected encoders" />
                            <TextBlock x:Name="CpuEncoderText" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock x:Name="GpuEncoderText" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <Button
                            Click="SaveButton_Click"
                            Content="Save Settings"
                            HorizontalAlignment="Left"
                            Style="{StaticResource GlassPrimaryButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </controls:GlassPanel.PanelContent>
        </controls:GlassPanel>
    </Grid>
</Page>
