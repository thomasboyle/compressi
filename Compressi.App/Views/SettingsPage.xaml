<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Compressi_App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Compressi_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <controls:GlassPanel>
            <controls:GlassPanel.PanelContent>
                <ScrollViewer>
                    <StackPanel Spacing="20" MaxWidth="640">
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="Settings" />

                        <TextBox
                            x:Name="OutputFolderBox"
                            Header="Default output folder"
                            PlaceholderText="Leave empty to use source file folder" />

                        <ComboBox x:Name="DefaultPresetBox" Header="Default Compression Mode" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Ultra" Tag="Ultra" />
                            <ComboBoxItem Content="8MB" Tag="EightMB" />
                            <ComboBoxItem Content="Balanced" Tag="Balanced" />
                        </ComboBox>

                        <ToggleSwitch x:Name="HardwareToggle" Header="Hardware acceleration (GPU AV1 when available)" />

                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="CPU thread usage" />
                            <Slider
                                x:Name="ThreadSlider"
                                Maximum="64"
                                Minimum="0"
                                StepFrequency="1"
                                ValueChanged="ThreadSlider_ValueChanged" />
                            <TextBlock x:Name="ThreadCountLabel" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <ComboBox x:Name="ThemeBox" Header="Theme" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="System" Tag="System" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>

                        <ToggleSwitch x:Name="NotifyToggle" Header="Notification on completion" />

                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="Detected encoders" />
                            <TextBlock x:Name="CpuEncoderText" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock x:Name="GpuEncoderText" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <Button
                            Click="SaveButton_Click"
                            Content="Save Settings"
                            HorizontalAlignment="Left"
                            Style="{StaticResource GlassPrimaryButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </controls:GlassPanel.PanelContent>
        </controls:GlassPanel>
    </Grid>
</Page>
