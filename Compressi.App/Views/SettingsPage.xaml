<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Compressi_App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Compressi_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <controls:GlassPanel>
            <controls:GlassPanel.PanelContent>
                <ScrollViewer>
                    <StackPanel
                        HorizontalAlignment="Center"
                        Spacing="20"
                        MaxWidth="640">
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="Settings" />

                        <InfoBar
                            x:Name="SettingsInfoBar"
                            IsClosable="True"
                            IsOpen="False" />

                        <TextBox
                            x:Name="OutputFolderBox"
                            Header="Default output folder"
                            PlaceholderText="Leave empty to use source file folder"
                            TextChanged="OutputFolderBox_TextChanged" />

                        <ComboBox
                            x:Name="DefaultPresetBox"
                            Header="Default preset"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="DefaultPresetBox_SelectionChanged">
                            <ComboBoxItem
                                Content="Ultra"
                                Tag="Ultra"
                                ToolTipService.ToolTip="Smallest file size with reduced video quality. Best for archiving or slow connections." />
                            <ComboBoxItem
                                Content="8 MB Target (Recommended)"
                                Tag="EightMB"
                                ToolTipService.ToolTip="Targets an 8 MB file while keeping audio and frame rate as high as possible. Great for Discord and chat sharing." />
                            <ComboBoxItem
                                Content="Balanced"
                                Tag="Balanced"
                                ToolTipService.ToolTip="Solid quality-to-size tradeoff for everyday sharing." />
                        </ComboBox>

                        <ToggleSwitch
                            x:Name="HardwareToggle"
                            Header="Hardware acceleration (GPU AV1 when available)"
                            Toggled="HardwareToggle_Toggled" />

                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="CPU thread usage" />
                            <Slider
                                x:Name="ThreadSlider"
                                Maximum="64"
                                Minimum="0"
                                StepFrequency="1"
                                ValueChanged="ThreadSlider_ValueChanged" />
                            <TextBlock x:Name="ThreadCountLabel" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <ComboBox
                            x:Name="ThemeBox"
                            Header="Theme"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="ThemeBox_SelectionChanged">
                            <ComboBoxItem Content="System" Tag="System" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>

                        <StackPanel Spacing="4">
                            <ToggleSwitch
                                x:Name="NotifyToggle"
                                Header="Notification on completion"
                                Toggled="NotifyToggle_Toggled" />
                            <TextBlock
                                x:Name="NotifyUnavailableText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="Desktop notifications are unavailable in this install."
                                TextWrapping="WrapWholeWords"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="UiSoundsToggle"
                            Header="UI interaction sounds"
                            Toggled="UiSoundsToggle_Toggled" />

                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="UI sound volume" />
                            <Slider
                                x:Name="UiSoundVolumeSlider"
                                Maximum="100"
                                Minimum="0"
                                StepFrequency="1"
                                ValueChanged="UiSoundVolumeSlider_ValueChanged" />
                            <TextBlock x:Name="UiSoundVolumeLabel" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="Detected encoders" />
                            <TextBlock x:Name="CpuEncoderText" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock x:Name="GpuEncoderText" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>

                        <Button
                            Click="SaveButton_Click"
                            Content="Save Settings"
                            HorizontalAlignment="Left"
                            Style="{StaticResource GlassPrimaryButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </controls:GlassPanel.PanelContent>
        </controls:GlassPanel>
    </Grid>
</Page>
