<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Compressi_App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Compressi_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <controls:GlassPanel>
            <controls:GlassPanel.PanelContent>
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource TitleTextStyle}" Text="History" />

                    <TextBox
                        x:Name="SearchBox"
                        Grid.Row="1"
                        PlaceholderText="Search by filename"
                        TextChanged="SearchBox_TextChanged" />

                    <ListView x:Name="HistoryList" Grid.Row="2">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding SourceName}" />
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding CreatedAtDisplay}" />
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding StatusDisplay}" />
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{StaticResource CaptionTextStyle}">
                                            <Run Text="{Binding OriginalSizeDisplay}" />
                                            <Run Text=" → " />
                                            <Run Text="{Binding CompressedSizeDisplay}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding RatioDisplay}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                        <Button
                                            Click="OpenFolderButton_Click"
                                            Content="Folder"
                                            Style="{StaticResource GlassSecondaryButtonStyle}"
                                            Tag="{Binding}" />
                                        <Button
                                            Click="RerunButton_Click"
                                            Content="Re-run"
                                            Style="{StaticResource GlassSecondaryButtonStyle}"
                                            Tag="{Binding}" />
                                        <Button
                                            Click="DeleteButton_Click"
                                            Content="Delete"
                                            Style="{StaticResource GlassSecondaryButtonStyle}"
                                            Tag="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        x:Name="EmptyText"
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        Opacity="0.5"
                        Style="{StaticResource BodyTextStyle}"
                        Text="No compression history yet."
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                </Grid>
            </controls:GlassPanel.PanelContent>
        </controls:GlassPanel>
    </Grid>
</Page>
