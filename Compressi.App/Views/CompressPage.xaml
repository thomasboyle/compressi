<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Compressi_App.Views.CompressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Compressi_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid ColumnSpacing="8" Padding="8,4,4,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="47*" />
            <ColumnDefinition Width="53*" />
        </Grid.ColumnDefinitions>

        <controls:GlassPanel Grid.Column="0">
            <controls:GlassPanel.PanelContent>
                <ScrollViewer
                    x:Name="LeftScrollViewer"
                    VerticalScrollBarVisibility="Hidden"
                    SizeChanged="LeftScrollViewer_SizeChanged">
                    <Grid x:Name="LeftContentRoot" RowSpacing="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="220" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Style="{StaticResource SubtitleTextStyle}"
                                Text="1. Add Video" />

                            <Grid x:Name="DropZone" Grid.Row="1" MinHeight="194">
                                <Rectangle
                                    x:Name="DropZoneOutline"
                                    CacheMode="BitmapCache"
                                    RadiusX="10"
                                    RadiusY="10"
                                    Fill="{StaticResource DropZoneFillBrush}"
                                    IsHitTestVisible="False"
                                    Stroke="{StaticResource DropZoneStrokeBrush}"
                                    StrokeDashArray="4,3"
                                    StrokeThickness="2.5" />
                                <Border
                                    x:Name="DropZoneHitTarget"
                                    AllowDrop="True"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    DragOver="DropZone_DragOver"
                                    Drop="DropZone_Drop"
                                    PointerEntered="DropZone_PointerEntered"
                                    PointerExited="DropZone_PointerExited"
                                    Tapped="DropZone_Tapped" />
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6">
                                    <ProgressRing
                                        x:Name="ProbeProgressRing"
                                        IsActive="False"
                                        IsHitTestVisible="False"
                                        Visibility="Collapsed" />
                                    <Image
                                        x:Name="DropZoneIcon"
                                        Width="52"
                                        Height="52"
                                        IsHitTestVisible="False"
                                        Source="{StaticResource IconCameraAddBitmap}"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        x:Name="DropZoneText"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="Drag &amp; drop a video file here" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        IsHitTestVisible="False"
                                        Opacity="0.7"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="or" />
                                    <Button
                                        x:Name="BrowseFilesButton"
                                        Click="BrowseFilesButton_Click"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource GlassSecondaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Image
                                                Width="16"
                                                Height="16"
                                                Source="{StaticResource IconFolderBitmap}"
                                                Stretch="Uniform" />
                                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="Browse Files" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Image
                                    Width="94"
                                    Height="118"
                                    Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    IsHitTestVisible="False"
                                    Source="{StaticResource DecoLeafSprigBitmap}"
                                    Stretch="Uniform" />
                            </Grid>

                            <StackPanel Grid.Row="2" Spacing="8">
                                <Border
                                    x:Name="StatusBanner"
                                    Style="{StaticResource GlassInfoBannerStyle}"
                                    Visibility="Collapsed">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock
                                                x:Name="StatusBannerTitle"
                                                Style="{StaticResource BodyTextStyle}"
                                                FontFamily="{StaticResource AppPixelFontBoldFamily}"
                                                Visibility="Collapsed" />
                                            <TextBlock
                                                x:Name="StatusBannerMessage"
                                                Style="{StaticResource BodyTextStyle}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button
                                            x:Name="StatusBannerActionButton"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Click="StatusInfoBarActionButton_Click"
                                            Style="{StaticResource GlassSecondaryButtonStyle}"
                                            Visibility="Collapsed" />
                                        <Button
                                            x:Name="StatusBannerCloseButton"
                                            Grid.Column="2"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            AutomationProperties.Name="Dismiss status"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="StatusBannerCloseButton_Click"
                                            Content="&#xE711;"
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Foreground="{StaticResource ResultLabelBrush}" />
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="FileChip"
                                    Padding="12"
                                    Background="{StaticResource ResultSurfaceBrush}"
                                    BorderBrush="{StaticResource ResultCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Visibility="Collapsed">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image
                                            Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            Source="{StaticResource IconCameraAddSmallBitmap}"
                                            Stretch="Uniform" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock x:Name="FileNameText" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock
                                                x:Name="FileMetadataText"
                                                Foreground="{StaticResource ResultLabelBrush}"
                                                Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                        <Button
                                            x:Name="RemoveFileButton"
                                            Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            AutomationProperties.Name="Remove selected file"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="RemoveFileButton_Click"
                                            Content="&#xE711;"
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            ToolTipService.ToolTip="Remove selected file" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="2. Output Settings" />

                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Format" />
                                <Grid ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton
                                        x:Name="Mp4FormatButton"
                                        Grid.Column="0"
                                        Checked="FormatRadioButton_Checked"
                                        Content="MP4"
                                        GroupName="OutputFormat"
                                        Style="{StaticResource GlassFormatRadioButtonStyle}"
                                        Tag="Mp4"
                                        ToolTipService.ToolTip="Best compatibility" />
                                    <RadioButton
                                        x:Name="MkvFormatButton"
                                        Grid.Column="1"
                                        Checked="FormatRadioButton_Checked"
                                        Content="MKV"
                                        GroupName="OutputFormat"
                                        Style="{StaticResource GlassFormatRadioButtonStyle}"
                                        Tag="Mkv"
                                        ToolTipService.ToolTip="Flexible container" />
                                    <RadioButton
                                        x:Name="WebmFormatButton"
                                        Grid.Column="2"
                                        Checked="FormatRadioButton_Checked"
                                        Content="WebM"
                                        GroupName="OutputFormat"
                                        Style="{StaticResource GlassFormatRadioButtonStyle}"
                                        Tag="WebM"
                                        ToolTipService.ToolTip="Web-friendly container (AV1 only)" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Codec" />
                                <Grid ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton
                                        x:Name="H264CodecButton"
                                        Grid.Column="0"
                                        Checked="CodecRadioButton_Checked"
                                        Content="H.264"
                                        GroupName="VideoCodec"
                                        Style="{StaticResource GlassFormatRadioButtonStyle}"
                                        Tag="H264"
                                        ToolTipService.ToolTip="Widest device and player support" />
                                    <RadioButton
                                        x:Name="Av1CodecButton"
                                        Grid.Column="1"
                                        Checked="CodecRadioButton_Checked"
                                        Content="AV1"
                                        GroupName="VideoCodec"
                                        Style="{StaticResource GlassFormatRadioButtonStyle}"
                                        Tag="Av1"
                                        ToolTipService.ToolTip="Smaller files at the same quality" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Preset" />
                                <ComboBox
                                    x:Name="PresetComboBox"
                                    SelectedIndex="1"
                                    SelectionChanged="PresetComboBox_SelectionChanged"
                                    Style="{StaticResource GlassInputComboBoxStyle}">
                                    <ComboBoxItem
                                        Content="Ultra"
                                        Tag="Ultra"
                                        ToolTipService.ToolTip="Smallest file size with reduced video quality. Best for archiving or slow connections." />
                                    <ComboBoxItem
                                        Content="8MB"
                                        Tag="EightMB"
                                        ToolTipService.ToolTip="Targets an 8MB file while keeping audio and frame rate as high as possible. Great for Discord and chat sharing." />
                                    <ComboBoxItem
                                        Content="Balanced"
                                        Tag="Balanced"
                                        ToolTipService.ToolTip="Solid quality-to-size tradeoff for everyday sharing." />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <ToggleButton
                                    x:Name="AdvancedToggle"
                                    Click="AdvancedToggle_Click"
                                    Content="Advanced Options"
                                    Style="{StaticResource GlassDisclosureToggleStyle}" />
                                <StackPanel
                                    x:Name="AdvancedOptionsPanel"
                                    x:Load="False"
                                    Padding="0,8,0,0"
                                    Spacing="12"
                                    Visibility="Collapsed">
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Resolution override" />
                                        <TextBox
                                            x:Name="ResolutionOverrideBox"
                                            PlaceholderText="e.g. 1920x1080"
                                            Style="{StaticResource GlassTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Frame rate override" />
                                        <TextBox
                                            x:Name="FrameRateOverrideBox"
                                            PlaceholderText="e.g. 30"
                                            Style="{StaticResource GlassTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Audio bitrate (kbps)" />
                                        <TextBox
                                            x:Name="AudioBitrateOverrideBox"
                                            PlaceholderText="128"
                                            Style="{StaticResource GlassTextBoxStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch
                                        x:Name="KeepAudioToggle"
                                        Style="{StaticResource GlassToggleSwitchStyle}"
                                        Toggled="KeepAudioToggle_Toggled">
                                        <ToggleSwitch.Header>
                                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="Keep original audio track" />
                                        </ToggleSwitch.Header>
                                    </ToggleSwitch>
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource GlassFieldLabelStyle}" Text="Output filename pattern" />
                                        <TextBox
                                            x:Name="OutputPatternBox"
                                            PlaceholderText="{}{name}_compressed"
                                            Style="{StaticResource GlassTextBoxStyle}" />
                                    </StackPanel>
                                    <Button
                                        x:Name="ChooseOutputFolderButton"
                                        Click="ChooseOutputFolderButton_Click"
                                        Content="Choose output folder"
                                        Style="{StaticResource GlassSecondaryButtonStyle}" />
                                    <TextBlock
                                        x:Name="OutputFolderPathText"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        Style="{StaticResource CaptionTextStyle}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel
                                x:Name="EncodingProgressPanel"
                                x:Load="False"
                                Spacing="8"
                                Visibility="Collapsed">
                                <ProgressBar
                                    x:Name="EncodingProgressBar"
                                    Foreground="{StaticResource PrimaryBlueBrush}"
                                    Maximum="100"
                                    Value="0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Name="ElapsedText"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Elapsed: 0:00" />
                                    <TextBlock
                                        x:Name="RemainingText"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Remaining: --:--" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Name="OutputSizeText"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Output: 0 MB" />
                                    <TextBlock
                                        x:Name="SpeedText"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        Style="{StaticResource CaptionTextStyle}" />
                                </Grid>
                            </StackPanel>

                            <Button
                                x:Name="CancelCompressionButton"
                                Click="CancelCompressionButton_Click"
                                Content="Cancel Compression"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource GlassSecondaryButtonStyle}"
                                Visibility="Collapsed" />

                            <Button
                                x:Name="StartCompressionButton"
                                Click="StartCompressionButton_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="False"
                                Style="{StaticResource GlassPrimaryButtonStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Image
                                        Width="18"
                                        Height="18"
                                        Source="{StaticResource IconLeafBitmap}"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        FontWeight="{StaticResource FontWeightSemiBold}"
                                        Foreground="{ThemeResource AppInkBrush}"
                                        Text="Start Compression" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </controls:GlassPanel.PanelContent>
        </controls:GlassPanel>

        <controls:GlassPanel Grid.Column="1">
            <controls:GlassPanel.PanelContent>
                <Grid>
                    <Grid x:Name="EmptyCompletePanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource SubtitleTextStyle}"
                            Text="3. Results" />

                        <StackPanel
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                            <Image
                                Width="128"
                                Height="112"
                                HorizontalAlignment="Center"
                                Source="{StaticResource ResultsEmptyBitmap}"
                                Stretch="Uniform" />

                            <StackPanel HorizontalAlignment="Center" Spacing="6" MaxWidth="360">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="{StaticResource FontWeightSemiBold}"
                                    FontFamily="{StaticResource AppPixelFontBoldFamily}"
                                    Foreground="{ThemeResource AppInkBrush}"
                                    Text="Your results will appear here"
                                    TextAlignment="Center" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource ResultLabelBrush}"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="Add a video and start compression to see preview, file details and compression stats."
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Row="2"
                            Padding="12,10"
                            Background="{StaticResource SecurityBannerFillBrush}"
                            BorderBrush="{StaticResource SecurityBannerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Grid.Column="0"
                                    Width="26"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Source="{StaticResource IconShieldBitmap}"
                                    Stretch="Uniform" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        FontWeight="{StaticResource FontWeightSemiBold}"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="Private &amp; Secure" />
                                    <TextBlock
                                        Foreground="{StaticResource ResultLabelBrush}"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Your files never leave your device. Everything is processed locally."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Deferred: large completion UI is unused until the first successful encode. -->
                    <ScrollViewer
                        x:Name="ResultPanel"
                        x:Load="False"
                        Visibility="Collapsed"
                        VerticalScrollBarVisibility="Auto"
                        SizeChanged="ResultPanel_SizeChanged">
                        <Grid x:Name="ResultContentRoot" RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="220" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="3. Compression Complete" />
                                <StackPanel
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <FontIcon
                                        FontSize="16"
                                        Foreground="{StaticResource SuccessGreenBrush}"
                                        Glyph="&#xE73E;" />
                                    <TextBlock
                                        Foreground="{StaticResource SuccessGreenBrush}"
                                        FontWeight="{StaticResource FontWeightSemiBold}"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="Completed" />
                                </StackPanel>
                            </Grid>

                            <Border
                                x:Name="PreviewHost"
                                Grid.Row="1"
                                Background="#12000000"
                                CornerRadius="12"
                                MinHeight="220" />

                            <Border
                                Grid.Row="2"
                                Background="{StaticResource ResultSurfaceBrush}"
                                BorderBrush="{StaticResource ResultCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,12">
                                <StackPanel Spacing="0">
                                    <Grid Margin="0,0,0,12" ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="1"
                                            FontWeight="{StaticResource FontWeightSemiBold}"
                                            Foreground="{StaticResource PrimaryBlueBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Original File" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontWeight="{StaticResource FontWeightSemiBold}"
                                            Foreground="{StaticResource SuccessGreenBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Compressed File" />
                                    </Grid>

                                    <Grid
                                        Padding="0,10"
                                        ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="File Name" />
                                        <TextBlock
                                            x:Name="OriginalNameText"
                                            Grid.Column="1"
                                            Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock
                                            x:Name="CompressedNameText"
                                            Grid.Column="2"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </Grid>
                                    <Border BorderBrush="{StaticResource ResultCardBorderBrush}" BorderThickness="0,1,0,0" />

                                    <Grid
                                        Padding="0,10"
                                        ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Format" />
                                        <TextBlock
                                            x:Name="OriginalFormatText"
                                            Grid.Column="1"
                                            Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock
                                            x:Name="CompressedFormatText"
                                            Grid.Column="2"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </Grid>
                                    <Border BorderBrush="{StaticResource ResultCardBorderBrush}" BorderThickness="0,1,0,0" />

                                    <Grid
                                        Padding="0,10"
                                        ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Resolution" />
                                        <TextBlock
                                            x:Name="OriginalResolutionText"
                                            Grid.Column="1"
                                            Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock
                                            x:Name="CompressedResolutionText"
                                            Grid.Column="2"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </Grid>
                                    <Border BorderBrush="{StaticResource ResultCardBorderBrush}" BorderThickness="0,1,0,0" />

                                    <Grid
                                        Padding="0,10"
                                        ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Duration" />
                                        <TextBlock
                                            x:Name="OriginalDurationText"
                                            Grid.Column="1"
                                            Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock
                                            x:Name="CompressedDurationText"
                                            Grid.Column="2"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </Grid>
                                    <Border BorderBrush="{StaticResource ResultCardBorderBrush}" BorderThickness="0,1,0,0" />

                                    <Grid
                                        Padding="0,10"
                                        ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="File Size" />
                                        <TextBlock
                                            x:Name="OriginalSizeText"
                                            Grid.Column="1"
                                            Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock
                                            x:Name="CompressedSizeText"
                                            Grid.Column="2"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="3" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Padding="16,12"
                                    Background="{StaticResource ResultSurfaceBrush}"
                                    BorderBrush="{StaticResource ResultCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Compression Ratio" />
                                        <TextBlock x:Name="RatioStatText" Style="{StaticResource ResultStatValueStyle}" />
                                        <TextBlock
                                            x:Name="SavedStatText"
                                            Foreground="{StaticResource SuccessGreenBrush}"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Grid.Column="1"
                                    Padding="16,12"
                                    Background="{StaticResource ResultSurfaceBrush}"
                                    BorderBrush="{StaticResource ResultCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Time Taken" />
                                        <TextBlock x:Name="TimeStatText" Style="{StaticResource ResultStatValueStyle}" />
                                        <TextBlock
                                            Foreground="{StaticResource SuccessGreenBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Completed" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Grid.Column="2"
                                    Padding="16,12"
                                    Background="{StaticResource ResultSurfaceBrush}"
                                    BorderBrush="{StaticResource ResultCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Foreground="{StaticResource ResultLabelBrush}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="Average Speed" />
                                        <TextBlock x:Name="SpeedStatText" Style="{StaticResource ResultStatValueStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="12">
                                <Button
                                    x:Name="OpenOutputFileButton"
                                    Click="OpenOutputFileButton_Click"
                                    Style="{StaticResource GlassSecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="Open Output File" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="OpenOutputFolderButton"
                                    Click="OpenOutputFolderButton_Click"
                                    Style="{StaticResource GlassSecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE838;" />
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="Open Output Folder" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="CompressAnotherButton"
                                    Click="CompressAnotherButton_Click"
                                    Style="{StaticResource GlassSecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                        <TextBlock Style="{StaticResource BodyTextStyle}" Text="Compress Another" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </controls:GlassPanel.PanelContent>
        </controls:GlassPanel>
    </Grid>
</Page>
